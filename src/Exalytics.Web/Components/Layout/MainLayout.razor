@inherits LayoutComponentBase

<div class="site">
    <header class="navbar">
        <nav class="nav-inner" aria-label="Main navigation">
            <a href="/" class="brand" aria-label="Exalytics home">
                <span class="logo-crop" aria-hidden="true">
                    <img src="images/exalytics-logo.png" alt="" class="logo-mark" />
                </span>
                <span class="wordmark">exalytics<span class="ai">.ai</span></span>
            </a>

            <div class="nav-center">
                <NavLink href="/" Match="NavLinkMatch.All" class="nav-item">Home</NavLink>
                <NavLink href="/topics" class="nav-item">Topics</NavLink>
                <NavLink href="/series" class="nav-item">Series</NavLink>
                <NavLink href="/collaborate" class="nav-item">Collaborate</NavLink>
            </div>

            <div class="nav-right">
                <a href="/login" class="nav-login">Log In</a>
                <a href="/signup" class="btn btn-pill">Start Free Trial</a>
            </div>
        </nav>
    </header>

    <main class="site-main">
        @Body
    </main>

    <footer class="footer">
        <div class="footer-grid">
            <div>
                <a href="/" class="footer-brand">exalytics.ai</a>
                <p class="footer-blurb">Economic data dashboards, modeled and visualized for analysts, SMEs and curious readers.</p>
            </div>

            <div>
                <div class="footer-h">Topics</div>
                <div class="footer-links">
                    <a href="/topics">Balance of Payments</a>
                    <a href="/topics">Trade Deficit</a>
                    <a href="/topics">Fiscal Deficit</a>
                    <a href="/topics">Inflation Tracker</a>
                    <a href="/topics">Oil &amp; Energy</a>
                </div>
            </div>

            <div>
                <div class="footer-h">Product</div>
                <div class="footer-links">
                    <a href="/#pricing">Pricing</a>
                    <a href="/series">Series Library</a>
                    <a href="/methodology">Methodology</a>
                    <a href="/docs">API Docs</a>
                </div>
            </div>

            <div>
                <div class="footer-h">Company</div>
                <div class="footer-links">
                    <a href="/about">About</a>
                    <a href="/collaborate">Collaborate</a>
                    <a href="/contact">Contact</a>
                    <a href="/privacy">Privacy Policy</a>
                    <a href="/terms">Terms of Service</a>
                </div>
            </div>
        </div>

        <div class="footer-copy">© 2026 Exalytics. All rights reserved.</div>
    </footer>
</div>
